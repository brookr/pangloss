# GitHub Configuration
GITHUB_TOKEN=your_github_personal_access_token

# OpenAI Configuration (for Codex CLI)
OPENAI_API_KEY=your_openai_api_key

# Anthropic Configuration (for Claude Code CLI)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Google Configuration (for Gemini CLI)
GEMINI_API_KEY=your_gemini_api_key
GOOGLE_API_KEY=your_google_api_key  # For Vertex AI (set GOOGLE_GENAI_USE_VERTEXAI=true)
GOOGLE_GENAI_USE_VERTEXAI=
GOOGLE_CLOUD_PROJECT=

# OpenRouter (optional) — access hundreds of models via codex.
# Enables the `openrouter` roster and ad-hoc `openrouter:<slug>` agents.
# Get a key at https://openrouter.ai/keys ; discover slugs with `pangloss models`.
OPENROUTER_API_KEY=your_openrouter_api_key

# Pangloss Configuration (optional - defaults will be used if not set)
PANGLOSS_CONFIG_PATH=./pangloss.config.json
PANGLOSS_TIMEOUT_MINUTES=30
PANGLOSS_MAX_PARALLEL_AGENTS=4

# Docker Configuration (optional)
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1
